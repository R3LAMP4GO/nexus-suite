generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum OnboardingStatus {
  PENDING_PAYMENT
  PENDING_SETUP
  ACTIVE
  SUSPENDED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum Platform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
  LINKEDIN
  X
  FACEBOOK
}

enum AccountType {
  PRIMARY
  SECONDARY
}

enum CircuitState {
  CLOSED
  OPEN
  HALF_OPEN
}

enum PostStatus {
  SCHEDULED
  POSTING
  SUCCESS
  FAILED
  SKIPPED
}

enum WarmupStatus {
  NOT_STARTED
  WARMING
  READY
}

enum PricingTier {
  PRO
  MULTIPLIER
  ENTERPRISE
}

enum ScriptStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

// ── Auth (NextAuth v5) ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  memberships   OrgMember[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Multi-Tenant: Organization ───────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe (SwaS)
  stripeCustomerId      String?  @unique
  stripeSubscriptionId  String?  @unique
  setupPaymentIntentId  String?

  // Status
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  onboardingStatus   OnboardingStatus   @default(PENDING_PAYMENT)
  pricingTier        PricingTier      @default(PRO)

  // Feature gates (denormalized from tier for fast checks)
  maxAccounts        Int     @default(3)
  maxWorkflowRuns    Int     @default(50)
  maxVideosPerMonth  Int     @default(30)
  mlFeaturesEnabled  Boolean @default(false)
  multiplierEnabled  Boolean @default(false)
  dailyLlmBudgetCents Int   @default(500) // 500 = $5/day Pro, 1500 = $15/day Multiplier

  // Brand
  brandConfig Json? // org-scoped brand voice, content strategy

  // Relations
  members              OrgMember[]
  platformTokens       OrgPlatformToken[]
  usageRecords         UsageRecord[]
  onboardingSubmission OnboardingSubmission?
  trackedCreators      TrackedCreator[]
  sourceVideos         SourceVideo[]
  postRecords          PostRecord[]
  scripts              Script[]
  workflows            Workflow[]
  workflowRuns         WorkflowRun[]
  hookPerformances     HookPerformance[]
}

// ── Multi-Tenant: Membership ─────────────────────────────────────

model OrgMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

// ── Platform Tokens (Infisical refs only — NO raw credentials) ──

model OrgPlatformToken {
  id             String   @id @default(cuid())
  organizationId String
  platform       Platform
  accountLabel   String   // human-readable label ("Main Brand", "Burner-TikTok-3")
  accountType    AccountType @default(PRIMARY)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Infisical Secret ID references — DB stores ONLY these paths
  // e.g. "orgs/{orgId}/tokens/{tokenId}" → resolved at runtime via Infisical SDK
  infisicalSecretPath String  // path to access/refresh tokens in Infisical
  infisicalProxyPath  String? // path to assigned proxy URL in Infisical (burners only)

  // Health tracking
  healthScore          Float        @default(1.0) // 0.0-1.0
  consecutiveFailures  Int          @default(0)
  circuitState         CircuitState @default(CLOSED)
  lastFailureAt        DateTime?
  lastSuccessAt        DateTime?

  // Browser automation (SECONDARY accounts only)
  fingerprintProfileId String?         @unique
  fingerprintProfile   BrowserProfile? @relation(fields: [fingerprintProfileId], references: [id])
  sessionStoragePath   String?         // R2 key: "sessions/{orgId}/{accountId}/state.json"
  warmupStatus         WarmupStatus    @default(NOT_STARTED)

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  postRecords       PostRecord[]
  warmingLogs       AccountWarmingLog[]
  proxyAllocations  ProxyAllocation[]

  @@unique([organizationId, platform, accountLabel])
  @@index([organizationId, platform])
  @@index([warmupStatus])
}

// ── Browser Fingerprint Profile (1:1 per burner account) ─────────

model BrowserProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Browser identity (generated once, reused consistently)
  userAgent           String
  screenWidth         Int
  screenHeight        Int
  hardwareConcurrency Int
  platform            String   // "Win32", "MacIntel", "Linux x86_64"
  languages           String[] // ["en-US", "en"]

  // Canvas/WebGL spoofing
  canvasNoiseSeed String // deterministic seed for canvas noise injection
  webglVendor     String // e.g. "NVIDIA Corporation"
  webglRenderer   String // e.g. "GeForce RTX 3060"

  // Locale
  timezone String // e.g. "America/New_York"
  locale   String // e.g. "en-US"

  // Back-reference
  platformToken OrgPlatformToken?
}

// ── Stripe Webhook Idempotency ───────────────────────────────────

model StripeEvent {
  id              String   @id // Stripe event ID (evt_xxx) — natural key for dedup
  type            String   // e.g. "checkout.session.completed"
  processedAt     DateTime @default(now())
  organizationId  String?  // linked org (if applicable)
  payload         Json?    // optional: store event payload for debugging

  @@index([type])
  @@index([organizationId])
}

// ── Usage Tracking (Tier Enforcement) ────────────────────────────

model UsageRecord {
  id             String   @id @default(cuid())
  organizationId String
  metric         String   // "accounts", "workflow_runs", "videos", "llm_spend_cents"
  period         String   // "2026-03" (monthly) or "2026-03-07" (daily for LLM)
  count          Int      @default(0)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, metric, period])
  @@index([organizationId, metric])
}

// ── Onboarding (Post-Payment Wizard) ─────────────────────────────

model OnboardingSubmission {
  id             String   @id @default(cuid())
  organizationId String   @unique
  submittedAt    DateTime @default(now())

  // Wizard data
  niche            String   // content vertical
  brandVoice       String?  @db.Text // brand voice description
  tonePreferences  String?  @db.Text // tone preferences
  competitorUrls   Json     @default("[]") // String[] of profile URLs
  platforms        Json     @default("[]") // Platform[] they want to target
  postingFrequency String?  // "daily", "3x/week", etc.
  contentStyle     String?  // "educational", "entertainment", etc.
  additionalNotes  String?  @db.Text

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ── Competitor Tracking ──────────────────────────────────────────

model TrackedCreator {
  id               String    @id @default(cuid())
  organizationId   String
  platform         Platform
  username         String
  profileUrl       String
  avatarUrl        String?
  followerCount    Int       @default(0)
  isActive         Boolean   @default(true)
  autoReproduce    Boolean   @default(false)
  outlierThreshold Float     @default(3.0)
  pollInterval     Int       @default(3600)
  lastPolledAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  posts        TrackedPost[]

  @@unique([organizationId, platform, username])
  @@index([organizationId])
  @@index([isActive, lastPolledAt])
}

model TrackedPost {
  id           String   @id @default(cuid())
  creatorId    String
  externalId   String
  title        String?
  url          String?
  thumbnailUrl String?
  views        Int      @default(0)
  likes        Int      @default(0)
  comments     Int      @default(0)
  publishedAt  DateTime?
  isOutlier    Boolean  @default(false)
  outlierScore Float?
  reproduced   Boolean  @default(false)
  analysis     Json?
  analyzedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator   TrackedCreator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  snapshots PostSnapshot[]

  @@unique([creatorId, externalId])
  @@index([creatorId])
  @@index([isOutlier])
}

model PostSnapshot {
  id         String   @id @default(cuid())
  postId     String
  views      Int      @default(0)
  likes      Int      @default(0)
  comments   Int      @default(0)
  capturedAt DateTime @default(now())

  post TrackedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, capturedAt])
}

// ── Multiplier Enums ──────────────────────────────────────────────

enum VariationStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum ProxyStatus {
  ACTIVE
  BURNED
  ROTATING
}

// ── Source Video ─────────────────────────────────────────────────

model SourceVideo {
  id             String   @id @default(cuid())
  organizationId String
  url            String
  platform       Platform
  r2StorageKey   String?
  duration       Int?     // seconds
  metadata       Json?
  scriptId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variations   VideoVariation[]
  script       Script?          @relation(fields: [scriptId], references: [id])

  @@index([organizationId])
  @@index([scriptId])
}

// ── Video Variation ─────────────────────────────────────────────

model VideoVariation {
  id               String   @id @default(cuid())
  sourceVideoId    String
  variationIndex   Int
  transforms       Json     // transformation parameters
  r2StorageKey     String?
  fileHash         String?
  pHash            String?  // perceptual hash
  audioFingerprint String?
  caption          String?  @db.Text
  status           String   @default("pending") // pending, processing, ready, failed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sourceVideo SourceVideo  @relation(fields: [sourceVideoId], references: [id], onDelete: Cascade)
  postRecords PostRecord[]

  @@unique([sourceVideoId, variationIndex])
  @@index([sourceVideoId])
}

// ── Post Record ─────────────────────────────────────────────────

model PostRecord {
  id             String     @id @default(cuid())
  organizationId String
  accountId      String
  variationId    String
  platform       Platform
  scheduledAt    DateTime
  postedAt       DateTime?
  status         PostStatus @default(SCHEDULED)
  externalPostId String?
  caption        String?    @db.Text
  errorMessage   String?    @db.Text
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account         OrgPlatformToken    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  variation       VideoVariation      @relation(fields: [variationId], references: [id], onDelete: Cascade)
  metricSnapshots PostMetricSnapshot[]

  @@index([organizationId, status])
  @@index([accountId, scheduledAt])
  @@index([status, scheduledAt])
}

// ── Post Metric Snapshots (Performance Tracking) ───────────────────

model PostMetricSnapshot {
  id             String   @id @default(cuid())
  postRecordId   String
  views          Int      @default(0)
  likes          Int      @default(0)
  comments       Int      @default(0)
  shares         Int      @default(0)
  saves          Int      @default(0)
  engagementRate Float    @default(0) // (likes+comments+shares) / views
  retentionRate  Float?   // Platform-reported average watch %
  snapshotAt     DateTime @default(now())

  postRecord PostRecord @relation(fields: [postRecordId], references: [id], onDelete: Cascade)

  @@index([postRecordId, snapshotAt])
}

// ── Hook Performance (A/B Feedback Loop) ───────────────────────────

model HookPerformance {
  id             String   @id @default(cuid())
  organizationId String
  hookText       String   @db.Text
  hookFramework  String?  // curiosity_gap, controversy, transformation, shock
  platform       Platform
  timesUsed      Int      @default(1)
  totalViews     Int      @default(0)
  totalLikes     Int      @default(0)
  totalComments  Int      @default(0)
  totalShares    Int      @default(0)
  avgEngagement  Float    @default(0) // Running average engagement rate
  avgRetention   Float?   // Running average retention rate
  score          Float    @default(0.5) // Thompson sampling score (0-1)
  alphaPrior     Float    @default(1)   // Beta distribution alpha (successes)
  betaPrior      Float    @default(1)   // Beta distribution beta (failures)
  lastUsedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, hookText, platform])
  @@index([organizationId, platform, score])
  @@index([organizationId, hookFramework])
}

model AccountWarmingLog {
  id        String   @id @default(cuid())
  accountId String
  phase     String
  action    String
  timestamp DateTime @default(now())
  success   Boolean

  account OrgPlatformToken @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model ProxyAllocation {
  id                String      @id @default(cuid())
  proxyIp           String
  provider          String
  status            ProxyStatus @default(ACTIVE)
  assignedAccountId String?
  lastBannedAt      DateTime?
  burnedReason      String?
  createdAt         DateTime    @default(now())

  assignedAccount OrgPlatformToken? @relation(fields: [assignedAccountId], references: [id])

  @@index([status])
  @@index([assignedAccountId])
}

// ── Script (Teleprompter Content) ────────────────────────────────

model Script {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  hookText       String       @db.Text // 0-3s opening hook
  bodyText       String       @db.Text // main body
  ctaText        String       @db.Text // call to action
  status         ScriptStatus @default(DRAFT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceVideos SourceVideo[]

  @@index([organizationId, status])
}

// ── Workflow Definition (DB-stored) ─────────────────────────────────

model Workflow {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?  @db.Text
  definition     Json     // Full WorkflowDefinition YAML/JSON
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs         WorkflowRun[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ── Workflow Run (Per-Execution Record) ─────────────────────────────

model WorkflowRun {
  id             String          @id @default(cuid())
  workflowId     String?
  workflow       Workflow?       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowName   String          // Denormalized for YAML-only workflows without DB record
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         String          @default("RUNNING") // RUNNING, COMPLETED, FAILED, CANCELLED
  triggeredBy    String?         // userId or "system"
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  durationMs     Int?
  error          String?         @db.Text
  metadata       Json?
  variables      Json?           // Final workflow variables snapshot
  steps          WorkflowStepLog[]

  @@index([workflowId])
  @@index([organizationId])
  @@index([status])
  @@index([organizationId, startedAt])
}

// ── Workflow Step Log (Per-Step Record) ──────────────────────────────

model WorkflowStepLog {
  id            String       @id @default(cuid())
  runId         String
  run           WorkflowRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepName      String
  stepType      String?      // action, agent-delegate, condition, forEach, while, parallel
  agentId       String?
  status        String       @default("RUNNING") // RUNNING, COMPLETED, FAILED, SKIPPED
  input         Json?
  output        Json?
  error         String?      @db.Text
  durationMs    Int?
  tokenUsage    Json?        // { prompt: number, completion: number, total: number }
  startedAt     DateTime     @default(now())
  completedAt   DateTime?

  @@index([runId])
}

// ── Workflow Run Log (Legacy — Agent Observability) ─────────────────

model WorkflowRunLog {
  id             String   @id @default(cuid())
  organizationId String
  runId          String   @unique
  workflowName   String
  status         String   // completed, failed, aborted
  startedAt      DateTime
  completedAt    DateTime
  durationMs     Int
  error          String?  @db.Text
  steps          Json     // Array of StepResult with prompts + outputs
  variables      Json?    // Final workflow variables

  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([status])
}
