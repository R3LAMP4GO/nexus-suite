# ── Database ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=nexus_dev
# For local dev (non-Docker). Docker services get this via docker-compose.yml.
DATABASE_URL=postgresql://nexus:nexus_dev@localhost:5500/nexus?schema=public
REDIS_URL=redis://localhost:6379

# ── Auth (NextAuth v5) ────────────────────────────────────────────
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# Set this to your production URL (e.g. https://app.yourdomain.com)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# ── Stripe (SwaS) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── LLM Providers ────────────────────────────────────────────────
ZHIPU_API_KEY=

# ── Cloudflare R2 (Object Storage) ───────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nexus-storage

# ── Infisical (Secrets Management) ───────────────────────────────
# Uses Infisical Cloud — no local Infisical container needed for dev.
# OAuth app credentials (Facebook, YouTube, etc.) are stored centrally
# and fetched at runtime, so you don't need them in your .env.
# Ask the project owner for your INFISICAL_CLIENT_ID/SECRET.
INFISICAL_SITE_URL=https://app.infisical.com/api
INFISICAL_PROJECT_ID=a3aa35c0-03f8-4bfe-9e7a-d5a7529f9f15
INFISICAL_ENV=dev
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
# Only needed for self-hosted Infisical (not needed for Cloud):
INFISICAL_ENCRYPTION_KEY=
INFISICAL_AUTH_SECRET=
INFISICAL_APP_CLIENT_ID=
INFISICAL_APP_CLIENT_SECRET=
INFISICAL_WORKER_CLIENT_ID=
INFISICAL_WORKER_CLIENT_SECRET=
INFISICAL_SCRAPER_CLIENT_ID=
INFISICAL_SCRAPER_CLIENT_SECRET=
INFISICAL_WARMING_CLIENT_ID=
INFISICAL_WARMING_CLIENT_SECRET=
INFISICAL_MEDIA_CLIENT_ID=
INFISICAL_MEDIA_CLIENT_SECRET=

# ── Proxy (IPRoyal default) ──────────────────────────────────────
PROXY_PROVIDER=iproyal
PROXY_API_KEY=
PROXY_RESIDENTIAL_ENDPOINT=
PROXY_DATACENTER_ENDPOINT=

# ── Google OAuth (NextAuth login) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Platform OAuth (Social Connections) ──────────────────────────
# YouTube: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
# TikTok: https://developers.tiktok.com → Web Video Kit / Login Kit
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Instagram: https://developers.facebook.com → Instagram Graph API
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Facebook: https://developers.facebook.com → Facebook Login
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# LinkedIn: https://developer.linkedin.com → Auth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# X (Twitter): https://developer.twitter.com
X_CLIENT_ID=
X_CLIENT_SECRET=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Nexus Suite <noreply@yourdomain.com>

# ── Stripe Price IDs (setup = one-time fee, subscription = recurring) ─
# These must match the IDs from your Stripe Dashboard → Products → Prices
STRIPE_PRO_SETUP_PRICE_ID=price_...
STRIPE_PRO_SUBSCRIPTION_PRICE_ID=price_...
STRIPE_MULTIPLIER_SETUP_PRICE_ID=price_...
STRIPE_MULTIPLIER_SUBSCRIPTION_PRICE_ID=price_...
STRIPE_ENTERPRISE_SETUP_PRICE_ID=price_...
STRIPE_ENTERPRISE_SUBSCRIPTION_PRICE_ID=price_...

# ── SMS / IMAP Verification ─────────────────────────────────────
VERIFICATION_PROVIDER=imap  # imap, smspool, or fivesim
FIVESIM_API_KEY=
SMSPOOL_API_KEY=
IMAP_HOST=
IMAP_USER=
IMAP_PASS=
IMAP_PORT=993
IMAP_TLS=true

# ── Scrapling ───────────────────────────────────────────────────
SCRAPLING_URL=http://localhost:8000

# ── Metrics ─────────────────────────────────────────────────────
METRICS_SECRET=change-me-in-production

# ── Platform API Mock Mode ────────────────────────────────────────
# Set to "true" to skip real HTTP calls to social platforms (dev/test)
MOCK_PLATFORM_APIS=false

# ── Sentry (error tracking) ────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Environment ──────────────────────────────────────────────────
NODE_ENV=development
