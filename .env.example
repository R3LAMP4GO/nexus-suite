# ── Database ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=nexus_dev
# For local dev (non-Docker). Docker services get this via docker-compose.yml.
DATABASE_URL=postgresql://postgres:nexus_dev@localhost:5432/nexus?schema=public
REDIS_URL=redis://localhost:6379

# ── Auth (NextAuth v5) ────────────────────────────────────────────
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# Set this to your production URL (e.g. https://app.yourdomain.com)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# ── Stripe (SwaS) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── LLM Providers ────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
ZHIPU_API_KEY=

# ── Cloudflare R2 (Object Storage) ───────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nexus-storage

# ── Infisical (Secrets Management) ───────────────────────────────
INFISICAL_ENCRYPTION_KEY=must-be-32-chars-for-production!
INFISICAL_AUTH_SECRET=dev-auth-secret-change-in-prod
INFISICAL_SITE_URL=http://localhost:8080
INFISICAL_PROJECT_ID=
INFISICAL_ENV=production
# For local dev (non-Docker) — code reads INFISICAL_CLIENT_ID/SECRET directly.
# Docker-compose maps the per-service vars below into INFISICAL_CLIENT_ID/SECRET.
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_APP_CLIENT_ID=
INFISICAL_APP_CLIENT_SECRET=
INFISICAL_WORKER_CLIENT_ID=
INFISICAL_WORKER_CLIENT_SECRET=
INFISICAL_SCRAPER_CLIENT_ID=
INFISICAL_SCRAPER_CLIENT_SECRET=
INFISICAL_WARMING_CLIENT_ID=
INFISICAL_WARMING_CLIENT_SECRET=
INFISICAL_MEDIA_CLIENT_ID=
INFISICAL_MEDIA_CLIENT_SECRET=

# ── Proxy (IPRoyal default) ──────────────────────────────────────
PROXY_PROVIDER=iproyal
PROXY_API_KEY=
PROXY_BASE_URL=
PROXY_RESIDENTIAL_ENDPOINT=
PROXY_DATACENTER_ENDPOINT=

# ── Google OAuth (NextAuth login) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Platform OAuth (Social Connections) ──────────────────────────
# YouTube: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
# TikTok: https://developers.tiktok.com → Web Video Kit / Login Kit
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Instagram: https://developers.facebook.com → Instagram Graph API
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Nexus Suite <noreply@yourdomain.com>

# ── Stripe Price IDs (setup = one-time fee, subscription = recurring) ─
# These must match the IDs from your Stripe Dashboard → Products → Prices
STRIPE_PRO_SETUP_PRICE_ID=price_...
STRIPE_PRO_SUBSCRIPTION_PRICE_ID=price_...
STRIPE_MULTIPLIER_SETUP_PRICE_ID=price_...
STRIPE_MULTIPLIER_SUBSCRIPTION_PRICE_ID=price_...
STRIPE_ENTERPRISE_SETUP_PRICE_ID=price_...
STRIPE_ENTERPRISE_SUBSCRIPTION_PRICE_ID=price_...

# ── SMS / IMAP Verification ─────────────────────────────────────
SMS_PROVIDER_API_KEY=
IMAP_HOST=
IMAP_USER=
IMAP_PASS=

# ── Scrapling ───────────────────────────────────────────────────
SCRAPLING_URL=http://localhost:8000

# ── X Platform ──────────────────────────────────────────────────
X_BEARER_TOKEN=

# ── Metrics ─────────────────────────────────────────────────────
METRICS_SECRET=change-me-in-production

# ── Environment ──────────────────────────────────────────────────
NODE_ENV=development
